{
  "name": "schoolfees",
  "version": "1.0.0",
  "description": "School Fees Management System for Nigerian Secondary Schools",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "node scripts/dev-start.js",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win --x64",
    "build:dir": "vite build && electron-builder --dir",
    "vite:only": "vite",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "googleapis": "^172.0.0",
    "lucide-react": "^0.383.0",
    "node-cron": "^4.2.1",
    "node-sqlite3-wasm": "^0.8.12",
    "nodemailer": "^8.0.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.3",
    "react-router-dom": "^6.22.3",
    "react-toastify": "^10.0.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.0.2",
    "electron-builder": "^24.13.3",
    "electron-store": "^8.2.0",
    "node-machine-id": "^1.1.12",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.11",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ojuoye.schoolfeesmanager",
    "productName": "SchoolFees Manager",
    "copyright": "Copyright © 2025 Ojuoye Moshood Olawale",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "!node_modules/electron",
      "!node_modules/.cache",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "database",
        "to": "database",
        "filter": ["**/*", "!*.lock"]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-sqlite3-wasm/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build-resources/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SchoolFees Manager",
      "installerIcon": "build-resources/icon.ico",
      "uninstallerIcon": "build-resources/icon.ico",
      "installerHeaderIcon": "build-resources/icon.ico",
      "deleteAppDataOnUninstall": false,
      "license": "build-resources/license.txt"
    },
    "publish": null
  }
}
